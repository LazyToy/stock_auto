# 한국투자증권 API 키 설정
# https://apiportal.koreainvestment.com 에서 발급받으세요

# 모의투자 (개발/테스트용)
KIS_APP_KEY=발급받은_앱키를_여기에_입력
KIS_APP_SECRET=발급받은_앱시크릿을_여기에_입력
KIS_ACCOUNT_NUMBER=모의투자_계좌번호_8자리
KIS_ACCOUNT_PRODUCT_CODE=01

# 실전투자 (운영용)
KIS_REAL_APP_KEY=실전투자_앱키
KIS_REAL_APP_SECRET=실전투자_앱시크릿
KIS_REAL_ACCOUNT_NUMBER=실전투자_계좌번호
KIS_REAL_ACCOUNT_PRODUCT_CODE=01

# 거래 모드 설정 (mock: 모의투자, real: 실전투자)
TRADING_MODE=mock

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 데이터 저장 경로
DATA_DIR=./data
REPORT_DIR=./reports

# ============================================
# 🆕 V2 신규 API 설정
# ============================================

# Google Gemini API (AI 기능용)
# https://aistudio.google.com/app/apikey 에서 발급
#
# ✅ 다중 키 지원: 콤마(,)로 구분하여 여러 개를 입력하세요
# 할당량 초과 시 다음 키로 자동 fallback
# 예시) GOOGLE_API_KEY=키1,키2,키3
GOOGLE_API_KEY=발급받은_Gemini_API_키

# Google Sheets 서비스 계정 경로 (크롤링용)
GOOGLE_SERVICE_ACCOUNT_FILE=config/google_service_account.json

# DART Open API (공시 분석용)
# https://opendart.fss.or.kr 에서 무료 인증키 신청
DART_API_KEY=발급받은_DART_인증키

# 카카오톡 알림 (선택)
# https://developers.kakao.com 에서 애플리케이션 생성 후 발급
KAKAO_REST_API_KEY=카카오_REST_API_키
KAKAO_ACCESS_TOKEN=카카오_액세스_토큰
KAKAO_REFRESH_TOKEN=카카오_리프레시_토큰

# 텔레그램 알림 (선택)
# @BotFather에서 봇 생성 후 발급
TELEGRAM_BOT_TOKEN=봇토큰
TELEGRAM_CHAT_ID=챗ID

# 디스코드 알림 (선택)
DISCORD_WEBHOOK_URL=디스코드_웹훅_URL
